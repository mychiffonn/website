---
import { PROFILE } from "@site-config"
import { cn } from "@/lib/utils"
import Icon from "@/components/base/Icon.astro"
import Link from "@/components/base/Link.astro"

import { getProcessedProfileLinks, type ProfileLinkConfig } from "./helper"

interface Props {
  links?: ProfileLinkConfig | Record<string, string>
  class?: string
  highlight?: boolean
  includeEmail?: boolean
  includeRss?: boolean
}

const {
  links,
  class: className = "",
  highlight = false,
  includeEmail = false,
  includeRss = false
} = Astro.props

const highlightKeys = new Set(PROFILE.highlightLinks)
const processedLinks = getProcessedProfileLinks(links, includeRss, includeEmail)
---

<ul class={`flex flex-wrap gap-x-2 gap-y-1 ${className}`}>
  {
    processedLinks.map(({ key, href, isExternal, label, iconName }) => {
      const isPrimary = highlight && highlightKeys.has(key)
      return (
        <li>
          <Link
            href={href}
            title={label}
            rel="me"
            class={cn(
              "flex touch-manipulation items-center justify-center rounded-md border transition-colors",
              "focus-visible:ring-ring size-11 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none",
              isPrimary
                ? "border-primary bg-primary text-primary-foreground hover:bg-background hover:text-primary hover:border-primary"
                : "text-muted-foreground hover:bg-accent hover:text-accent-foreground"
            )}
            external={isExternal}
          >
            <Icon name={iconName} class="size-5.5" />
            <span class="sr-only" set:html={label} />
          </Link>
        </li>
      )
    })
  }
</ul>
