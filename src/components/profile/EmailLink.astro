---
import CopyButton from "@/components/base/CopyButton.astro"
import Icon from "@/components/base/Icon.astro"
import Link from "@/components/base/Link.astro"

import { getTransformedEmail } from "./helper"

interface Props {
  email: string
  showIcon?: boolean
  showCopyButton?: boolean
}

const { email, showIcon = true, showCopyButton = true } = Astro.props
const displayEmail = getTransformedEmail(email, "display")
---

<span class="flex items-center gap-2">
  {showIcon && <Icon name="mingcute:mail-line" class="size-5.5" />}
  <Link
    href={`mailto:${email}`}
    aria-label={`Send email to ${displayEmail}`}
    title={`Send email to ${displayEmail}`}
    external
  >
    {displayEmail}
  </Link>
  {
    showCopyButton && (
      <CopyButton
        text={email}
        title="Copy email address"
        size="1.5rem"
        class="hover:text-accent hover:ring-ring rounded p-1 transition-colors hover:ring-2"
      />
    )
  }
</span>
