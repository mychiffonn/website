---
import type { AuthorData } from "@/lib/blog/types"
import AuthorCard from "@/components/people/AuthorCard.astro"

interface Props {
  authors: AuthorData[]
}

const { authors } = Astro.props
if (authors.length === 0) return
const heading = authors.length === 1 ? "About the Author" : "About the Authors"
---

<section class="mt-2 flex flex-col gap-y-1">
  <h2 id="about-authors" class="section-title relative mt-4 mb-2 pb-0.5 text-2xl font-medium">
    {heading}
  </h2>
  <div class="authors-list flex flex-col gap-2">
    {authors.map((author) => <AuthorCard author={author} variant="compact" />)}
  </div>
</section>

<style>
  .section-title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2rem;
    height: 2px;
    background-color: var(--primary);
    border-radius: 1px;
    opacity: 0.7;
    transition: width 300ms ease-in-out;
  }

  section:hover .section-title::after {
    width: 3rem;
  }
</style>
