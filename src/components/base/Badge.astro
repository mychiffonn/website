---
import { cva, type VariantProps } from "class-variance-authority"

import { cn } from "@/lib/utils"

import Link from "./Link.astro"

const badgeVariants = cva(
  "inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 [&>svg]:size-3 gap-1 [&>svg]:pointer-events-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive transition-[color,box-shadow,background-color] [a&]:cursor-pointer overflow-hidden",
  {
    variants: {
      variant: {
        default:
          "border-transparent bg-primary text-primary-foreground [a&]:hover:bg-background [a&]:hover:text-foreground",
        accent:
          "border-transparent bg-accent text-accent-foreground [a&]:hover:bg-primary [a&]:hover:text-primary-foreground",
        destructive:
          "border-transparent bg-destructive text-white [a&]:hover:bg-destructive/80 focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40 dark:bg-destructive/80",
        outline:
          "border-primary text-foreground [a&]:hover:bg-primary [a&]:hover:text-primary-foreground",
        muted:
          "border-transparent bg-muted text-muted-foreground [a&]:hover:bg-accent [a&]:hover:text-accent-foreground",
        success:
          "border-transparent bg-green-500 text-white [a&]:hover:bg-green-500/20 [a&]:hover:text-green-700 dark:[a&]:hover:text-green-400 focus-visible:ring-green-500/20 dark:focus-visible:ring-green-500/40 dark:bg-green-600",
        warning:
          "border-transparent bg-yellow-500 text-white [a&]:hover:bg-yellow-500/20 [a&]:hover:text-yellow-700 dark:[a&]:hover:text-yellow-400 focus-visible:ring-yellow-500/20 dark:focus-visible:ring-yellow-500/40 dark:bg-yellow-600",
        danger:
          "border-transparent bg-red-500 text-white [a&]:hover:bg-red-500/20 [a&]:hover:text-red-700 dark:[a&]:hover:text-red-400 focus-visible:ring-red-500/20 dark:focus-visible:ring-red-500/40 dark:bg-red-600",
        info: "border-transparent bg-blue-500 text-white [a&]:hover:bg-blue-500/20 [a&]:hover:text-blue-700 dark:[a&]:hover:text-blue-400 focus-visible:ring-blue-500/20 dark:focus-visible:ring-blue-500/40 dark:bg-blue-600",
        tag: "bg-transparent border-border text-muted-foreground cursor-pointer transition-all hover:border-accent hover:text-accent aria-[pressed=true]:bg-primary aria-[pressed=true]:text-primary-foreground aria-[pressed=true]:border-primary"
      }
    },
    defaultVariants: {
      variant: "default"
    }
  }
)

export type BadgeVariant = VariantProps<typeof badgeVariants>["variant"]

export interface Props extends astroHTML.JSX.HTMLAttributes {
  variant?: BadgeVariant
  href?: string
  as?: "button"
}

const { variant = "default", class: className, href, as, ...rest } = Astro.props
---

{
  href ? (
    <Link href={href} data-slot="badge" class={cn(badgeVariants({ variant }), className)} {...rest}>
      <slot />
    </Link>
  ) : as === "button" ? (
    <button data-slot="badge" class={cn(badgeVariants({ variant }), className)} {...rest}>
      <slot />
    </button>
  ) : (
    <span data-slot="badge" class={cn(badgeVariants({ variant }), className)} {...rest}>
      <slot />
    </span>
  )
}
