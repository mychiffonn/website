---
import Button from "./Button.astro"
import Icon from "./Icon.astro"

interface Props {
  markdown: string
  class?: string
}

const { markdown, class: className } = Astro.props
---

<div class:list={["copy-markdown-wrapper", className]}>
  <Button variant="ghost" size="default" data-copy-markdown title="Copy as Markdown">
    <Icon name="copy" size="1rem" class="copy-icon" />
    <Icon name="check" size="1rem" class="check-icon hidden" />
    <span class="copy-label">Copy Markdown</span>
  </Button>
  <div hidden data-markdown-source>{JSON.stringify(markdown)}</div>
</div>

<script is:inline data-astro-rerun>
  ;(function () {
    function initCopyMarkdown() {
      document.querySelectorAll("[data-copy-markdown]").forEach(function (btn) {
        if (btn.hasAttribute("data-copy-bound")) return
        btn.setAttribute("data-copy-bound", "")

        btn.addEventListener("click", function () {
          var wrapper = btn.closest(".copy-markdown-wrapper")
          var source = wrapper && wrapper.querySelector("[data-markdown-source]")
          if (!source || !source.textContent) return

          var md = JSON.parse(source.textContent)
          navigator.clipboard.writeText(md).then(function () {
            var copyIcon = btn.querySelector(".copy-icon")
            var checkIcon = btn.querySelector(".check-icon")
            var label = btn.querySelector(".copy-label")

            if (copyIcon) copyIcon.classList.add("hidden")
            if (checkIcon) checkIcon.classList.remove("hidden")
            if (label) label.textContent = "Copied!"

            setTimeout(function () {
              if (copyIcon) copyIcon.classList.remove("hidden")
              if (checkIcon) checkIcon.classList.add("hidden")
              if (label) label.textContent = "Copy Markdown"
            }, 2000)
          })
        })
      })
    }

    initCopyMarkdown()
    document.addEventListener("astro:after-swap", initCopyMarkdown)
  })()
</script>
