---
import Link from "@/components/base/Link.astro"

interface Props {
  title: string
  class?: string
  /** Optional link to see more */
  moreLink?: string
  /** Custom more link text (defaults to "see all →") */
  moreText?: string
}

const { class: className, title, moreLink, moreText = "see all →" } = Astro.props
---

<section class:list={["mt-2 flex flex-col gap-y-1", className]}>
  <div class={moreLink && "flex items-baseline gap-x-3"}>
    <h2
      id={title.toLowerCase()}
      class="section-title relative mt-4 mb-2 pb-0.5 text-2xl font-medium"
    >
      {title}
    </h2>
    {
      moreLink && (
        <Link href={moreLink} underline class="text-muted-foreground text-sm">
          {moreText}
        </Link>
      )
    }
  </div>
  <slot />
</section>

<style>
  .section-title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2rem;
    height: 2px;
    background-color: var(--primary);
    border-radius: 1px;
    opacity: 0.7;
    transition: width 300ms ease-in-out;
  }

  section:hover .section-title::after {
    width: 3rem;
  }
</style>
