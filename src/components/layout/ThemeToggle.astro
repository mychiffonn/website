---
import Button from "@/components/base/Button.astro"
import Dropdown from "@/components/base/Dropdown.astro"
import Icon from "@/components/base/Icon.astro"
---

<Dropdown align="end" id="theme-dropdown">
  <Button slot="trigger" variant="ghost" size="square" title="Theme" data-dropdown-trigger>
    <Icon name="mingcute:sun-line" size="1.5rem" class="theme-icon-light" />
    <Icon name="mingcute:moon-line" size="1.5rem" class="theme-icon-dark" />
    <span class="sr-only">Toggle theme</span>
  </Button>

  <div class="bg-background">
    <button data-dropdown-item data-theme-value="light">
      <Icon name="mingcute:sun-line" size="1.25rem" />
      Light
    </button>
    <button data-dropdown-item data-theme-value="dark">
      <Icon name="mingcute:moon-line" size="1.25rem" />
      Dark
    </button>
    <button data-dropdown-item data-theme-value="auto">
      <Icon name="monitor" size="1.25rem" />
      Auto
    </button>
  </div>
</Dropdown>

<style>
  .theme-icon-light,
  .theme-icon-dark {
    position: absolute;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }
  .theme-icon-dark {
    opacity: 0;
    transform: scale(0);
  }
  :global([data-theme="dark"]) .theme-icon-light {
    opacity: 0;
    transform: scale(0);
  }
  :global([data-theme="dark"]) .theme-icon-dark {
    opacity: 1;
    transform: scale(1);
  }

  button[data-dropdown-item] {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid transparent;
    white-space: nowrap;
    transition: background-color 0.2s ease;
  }
  button[data-dropdown-item]:hover {
    background-color: color-mix(in oklch, var(--accent) 50%, transparent);
  }
  button[data-dropdown-item][data-active] {
    background-color: color-mix(in oklch, var(--primary) 80%, transparent);
    color: var(--primary-foreground);
    font-weight: 500;
  }
</style>

<script is:inline data-astro-rerun>
  ;(() => {
    const stored = localStorage?.getItem("theme") ?? "auto"
    const preference = ["light", "dark", "auto"].includes(stored) ? stored : "auto"
    const resolved =
      preference === "auto"
        ? window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light"
        : preference

    document.documentElement.setAttribute("data-theme", resolved)
    document.documentElement.classList.add(resolved === "dark" ? "scheme-dark" : "scheme-light")
    localStorage.setItem("theme", preference)
  })()
</script>

<script>
  function resolveTheme(preference: string): string {
    if (preference === "auto") {
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
    }
    return preference
  }

  function applyTheme(resolved: string) {
    const el = document.documentElement
    el.classList.add("[&_*]:transition-none")
    el.setAttribute("data-theme", resolved)
    el.classList.remove("scheme-dark", "scheme-light")
    el.classList.add(resolved === "dark" ? "scheme-dark" : "scheme-light")

    window.getComputedStyle(el).getPropertyValue("opacity")

    requestAnimationFrame(() => {
      el.classList.remove("[&_*]:transition-none")
    })
  }

  function updateActiveItem() {
    const stored = localStorage.getItem("theme") ?? "auto"
    document
      .querySelectorAll<HTMLButtonElement>("#theme-dropdown [data-theme-value]")
      .forEach((btn) => {
        if (btn.dataset.themeValue === stored) {
          btn.setAttribute("data-active", "")
        } else {
          btn.removeAttribute("data-active")
        }
      })
  }

  function handleThemeItemClick(e: Event) {
    const btn = (e.target as Element).closest<HTMLButtonElement>("[data-theme-value]")
    if (!btn) return
    const preference = btn.dataset.themeValue!
    localStorage.setItem("theme", preference)
    applyTheme(resolveTheme(preference))
    updateActiveItem()
  }

  function bindThemeHandlers() {
    const container = document.getElementById("theme-dropdown")
    if (!container || container.hasAttribute("data-theme-bound")) return
    container.setAttribute("data-theme-bound", "")
    container.addEventListener("click", handleThemeItemClick)
  }

  function initThemeDropdown() {
    bindThemeHandlers()
    updateActiveItem()
  }

  // Track OS changes for "auto" mode
  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
    const stored = localStorage.getItem("theme") ?? "auto"
    if (stored === "auto") {
      applyTheme(resolveTheme("auto"))
    }
  })

  initThemeDropdown()

  document.addEventListener("astro:after-swap", () => {
    const stored = localStorage.getItem("theme") ?? "auto"
    applyTheme(resolveTheme(stored))
    initThemeDropdown()
  })
</script>
