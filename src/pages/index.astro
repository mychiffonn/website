---
import { getCollection } from "astro:content"

import { PROFILE, SITE } from "@site-config"
import { PostManager } from "@/lib/blog"
import { loadSelectedPublications } from "@/lib/publications/loader"
import { getLatestUpdates } from "@/lib/updates"
import Layout from "@/layouts/Layout.astro"
import Button from "@/components/base/Button.astro"
import PreviewCard from "@/components/blog/PreviewCard.astro"
import Section from "@/components/layout/Section.astro"
import Profile from "@/components/profile/Profile.astro"
import PubCard from "@/components/publications/PubCard.astro"
import ExperienceTimeline from "@/components/timeline/ExperienceTimeline.astro"
import UpdatesInline from "@/components/timeline/UpdatesInline.astro"

import { Content as MiscContent, rawContent as miscRaw } from "@/content/misc.md"
import { Content as ServicesContent, rawContent as servicesRaw } from "@/content/services.md"

import "@/styles/sidenote.css"

const hasServices = servicesRaw().trim().length > 0
const hasMisc = miscRaw().trim().length > 0

const careerHighlights = await getCollection("experience")
const renderedUpdates = await getLatestUpdates(3)
const selectedPublications = await loadSelectedPublications()

// Blog
const postManager = PostManager.getInstance()
const recentPosts = await postManager.getMainPosts(SITE.blog.featuredPostCount)
const recentPostsMetadata = await Promise.all(
  recentPosts.map((post) => postManager.getMetadata(post.id))
)
---

<Layout title="Home">
  <Profile profile={PROFILE} />

  {
    careerHighlights.length > 0 && (
      <Section
        title="Career highlights"
        moreLink="/doc/My_Chiffon_Nguyen_CV.pdf"
        moreText="see CV →"
      >
        <ExperienceTimeline entries={careerHighlights} />
      </Section>
    )
  }

  {
    renderedUpdates.length > 0 && (
      <Section title="Latest updates" moreLink="/now">
        <UpdatesInline renderedUpdates={renderedUpdates} itemClass="line-clamp-4 md:line-clamp-3" />
      </Section>
    )
  }

  {
    selectedPublications.length > 0 && (
      <Section title="Selected publications" moreLink="/publications">
        <div class="space-y-4">
          {selectedPublications.slice(0, 3).map((pub) => (
            <PubCard pub={pub} />
          ))}
        </div>
      </Section>
    )
  }
  {
    recentPostsMetadata.length > 0 && (
      <Section title="Latest posts">
        <ul class="flex flex-col gap-y-2">
          {recentPostsMetadata.map((metadata) => (
            <li>
              <PreviewCard metadata={metadata} />
            </li>
          ))}
        </ul>
        <div class="mt-4 flex justify-center gap-2">
          <Button href="/blog" variant="default" class="group">
            See all posts <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </Button>
          <Button href="/blog/tags" variant="ghost" class="group">
            Browse by tags{" "}
            <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </Button>
        </div>
      </Section>
    )
  }

  {
    hasServices && (
      <Section title="Services">
        <div class="prose">
          <ServicesContent />
        </div>
      </Section>
    )
  }

  {
    hasMisc && (
      <Section title="Miscellaneous">
        <div class="prose">
          <MiscContent />
        </div>
      </Section>
    )
  }
</Layout>
