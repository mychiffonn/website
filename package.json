{
  "name": "astro-scholar",
  "type": "module",
  "version": "1.2.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format": "prettier --write **/*.{astro,ts,tsx,css,mjs,md,mdx} --ignore-path .gitignore",
    "lint": "pnpm dlx oxlint --type-aware",
    "routine": "pnpm lint && pnpm sync && pnpm format",
